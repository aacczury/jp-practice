{"lessons": [{"id": "day01", "title": "Day 1 — morning together", "audio": "audio/day01.mp3", "lines": [{"spk": "her", "ja": "おはよう。よく寝た？", "romaji": "Ohayou. Yoku neta?", "meaning": "Good morning. Did you sleep well?", "start": 0.0, "end": 1.69}, {"spk": "me", "ja": "おはよう。うん、よく寝たよ。", "romaji": "Ohayou. Un, yoku neta yo.", "meaning": "Morning. Yeah, I slept well.", "start": 2.4, "end": 4.94}, {"spk": "her", "ja": "朝ごはん、できてるよ。", "romaji": "Asagohan, dekiteru yo.", "meaning": "Breakfast's ready.", "start": 5.66, "end": 7.53}, {"spk": "me", "ja": "ありがとう。いただきます。", "romaji": "Arigatou. Itadakimasu.", "meaning": "Thanks. (said before eating — ~\"let's eat / thanks for the food\")", "start": 8.33, "end": 10.33}, {"spk": "me", "ja": "ごちそうさま。美味しかった！", "romaji": "Gochisousama. Oishikatta!", "meaning": "Thanks for the meal (said after eating). It was delicious!", "start": 11.3, "end": 13.44}, {"spk": "her", "ja": "よかった。", "romaji": "Yokatta.", "meaning": "Glad to hear it.", "start": 14.17, "end": 15.04}]}, {"id": "day02", "title": "Day 2 — coming & going at home", "audio": "audio/day02.mp3", "lines": [{"spk": "me", "ja": "行ってきます！", "romaji": "Ittekimasu!", "meaning": "I'm off! (lit. I'll go and come back)", "start": 0.0, "end": 1.02}, {"spk": "her", "ja": "行ってらっしゃい。気をつけてね。", "romaji": "Itterasshai. Ki o tsukete ne.", "meaning": "Take care! Be careful, okay?", "start": 1.27, "end": 3.56}, {"spk": "me", "ja": "ただいま。", "romaji": "Tadaima.", "meaning": "I'm home.", "start": 5.1, "end": 5.92}, {"spk": "her", "ja": "おかえり。お疲れさま。", "romaji": "Okaeri. Otsukaresama.", "meaning": "Welcome back. Nice work.", "start": 6.23, "end": 8.2}, {"spk": "me", "ja": "お腹すいた〜。ご飯ある？", "romaji": "Onaka suita. Gohan aru?", "meaning": "I'm hungry~. Is there food?", "start": 8.53, "end": 12.64}, {"spk": "her", "ja": "うん、できてるよ。", "romaji": "Un, dekiteru yo.", "meaning": "Yeah, it's ready.", "start": 13.03, "end": 14.66}, {"spk": "me", "ja": "おやすみ。また明日。", "romaji": "Oyasumi. Mata ashita.", "meaning": "Good night. See you tomorrow.", "start": 15.1, "end": 17.18}, {"spk": "her", "ja": "おやすみ〜。", "romaji": "Oyasumi.", "meaning": "Night~.", "start": 17.61, "end": 18.8}]}, {"id": "day03", "title": "Day 3 — feelings & reactions at home", "audio": "audio/day03.mp3", "lines": [{"spk": "her", "ja": "おかえり！疲れた？", "romaji": "Okaeri! Tsukareta?", "meaning": "Welcome back! Are you tired?", "start": 0.0, "end": 1.74}, {"spk": "me", "ja": "ただいま。うん、ちょっと疲れた。", "romaji": "Tadaima. Un, chotto tsukareta.", "meaning": "I'm home. Yeah, a bit tired.", "start": 2.25, "end": 5.56}, {"spk": "her", "ja": "大丈夫？", "romaji": "Daijoubu?", "meaning": "Are you okay?", "start": 6.17, "end": 7.24}, {"spk": "me", "ja": "うん、大丈夫。ありがとう。", "romaji": "Un, daijoubu. Arigatou.", "meaning": "Yeah, I'm fine. Thanks.", "start": 7.65, "end": 10.02}, {"spk": "her", "ja": "今日、カレー作ったよ！", "romaji": "Kyou, karee tsukutta yo!", "meaning": "I made curry today!", "start": 10.72, "end": 12.52}, {"spk": "me", "ja": "ほんと？嬉しい！お腹すいた！", "romaji": "Honto? Ureshii! Onaka suita!", "meaning": "Really? I'm so happy! And I'm hungry!", "start": 13.05, "end": 16.76}, {"spk": "her", "ja": "じゃあ、食べよう！", "romaji": "Jaa, tabeyou!", "meaning": "Then let's eat!", "start": 17.48, "end": 18.76}, {"spk": "me", "ja": "美味しい！", "romaji": "Oishii!", "meaning": "It's delicious!", "start": 19.34, "end": 20.45}, {"spk": "her", "ja": "よかった〜！", "romaji": "Yokatta!", "meaning": "I'm glad!", "start": 21.0, "end": 22.16}]}, {"id": "day04", "title": "Day 4 — asking about things at home", "audio": "audio/day04.mp3", "lines": [{"spk": "me", "ja": "ね、リモコン、どこ？", "romaji": "Ne, rimokon, doko?", "meaning": "Hey, where's the remote?", "start": 0.0, "end": 1.71}, {"spk": "her", "ja": "テーブルの上だよ。", "romaji": "Teeburu no ue da yo.", "meaning": "On the table.", "start": 2.1, "end": 3.64}, {"spk": "me", "ja": "ないよ〜。", "romaji": "Nai yo.", "meaning": "It's not here~.", "start": 3.94, "end": 5.06}, {"spk": "her", "ja": "じゃあ、ソファの下は？", "romaji": "Jaa, sofa no shita wa?", "meaning": "Then how about under the sofa?", "start": 5.48, "end": 7.25}, {"spk": "me", "ja": "あった！", "romaji": "Atta!", "meaning": "Found it!", "start": 7.66, "end": 8.44}, {"spk": "her", "ja": "よかった。ね、それ取って。", "romaji": "Yokatta. Ne, sore totte.", "meaning": "Good. Hey, pass me that.", "start": 8.89, "end": 11.83}, {"spk": "me", "ja": "これ？なに、これ？", "romaji": "Kore? Nani, kore?", "meaning": "This? What is it?", "start": 12.29, "end": 14.39}, {"spk": "her", "ja": "プリン！半分食べる？", "romaji": "Purin! Hanbun taberu?", "meaning": "Pudding! Want half?", "start": 14.77, "end": 16.88}, {"spk": "me", "ja": "食べる！ありがとう！", "romaji": "Taberu! Arigatou!", "meaning": "I do! Thanks!", "start": 17.31, "end": 18.96}]}, {"id": "day05", "title": "Day 5 — weekend plans", "audio": "audio/day05.mp3", "lines": [{"spk": "her", "ja": "ねえ、今日何する？", "romaji": "Nee, kyou nani suru?", "meaning": "Hey, what shall we do today?", "start": 0.0, "end": 1.62}, {"spk": "me", "ja": "天気いいし、出かけよう！", "romaji": "Tenki ii shi, dekakeyou!", "meaning": "The weather's nice, so let's go out!", "start": 2.07, "end": 3.97}, {"spk": "her", "ja": "いいね！どこ行く？", "romaji": "Ii ne! Doko iku?", "meaning": "Nice! Where shall we go?", "start": 4.38, "end": 6.2}, {"spk": "me", "ja": "公園は？散歩しよう。", "romaji": "Kouen wa? Sanpo shiyou.", "meaning": "How about the park? Let's take a walk.", "start": 6.64, "end": 8.61}, {"spk": "her", "ja": "いいね。お弁当作ろうか？", "romaji": "Ii ne. Obentou tsukurou ka?", "meaning": "Good. Shall I make a bento?", "start": 9.0, "end": 11.85}, {"spk": "me", "ja": "ほんと？嬉しい！", "romaji": "Honto? Ureshii!", "meaning": "Really? I'm so happy!", "start": 12.25, "end": 13.95}, {"spk": "her", "ja": "じゃあ、準備しよう。", "romaji": "Jaa, junbi shiyou.", "meaning": "Then let's get ready.", "start": 14.45, "end": 15.92}, {"spk": "me", "ja": "うん、行こう！", "romaji": "Un, ikou!", "meaning": "Yeah, let's go!", "start": 16.28, "end": 17.52}]}, {"id": "day06", "title": "Day 6 — shopping together", "audio": "audio/day06.mp3", "lines": [{"spk": "her", "ja": "これ、かわいい！", "romaji": "Kore, kawaii!", "meaning": "This is cute!", "start": 0.0, "end": 1.52}, {"spk": "me", "ja": "ほんとだ。いくら？", "romaji": "Honto da. Ikura?", "meaning": "It really is. How much?", "start": 1.92, "end": 3.48}, {"spk": "her", "ja": "千二百円だって。", "romaji": "Sen nihyaku en datte.", "meaning": "It says 1,200 yen.", "start": 3.83, "end": 5.64}, {"spk": "me", "ja": "ちょっと高いね。", "romaji": "Chotto takai ne.", "meaning": "A bit pricey, huh.", "start": 5.97, "end": 7.39}, {"spk": "her", "ja": "でも、欲しい！", "romaji": "Demo, hoshii!", "meaning": "But I want it!", "start": 7.74, "end": 8.98}, {"spk": "me", "ja": "じゃあ、これにしよう。", "romaji": "Jaa, kore ni shiyou.", "meaning": "Then let's go with this one.", "start": 9.3, "end": 10.79}, {"spk": "her", "ja": "やった！ありがとう！", "romaji": "Yatta! Arigatou!", "meaning": "Yay! Thank you!", "start": 11.19, "end": 12.72}]}, {"id": "day07", "title": "Day 7 — ordering at a café", "audio": "audio/day07.mp3", "lines": [{"spk": "me", "ja": "すみません、メニューください。", "romaji": "Sumimasen, menyuu kudasai.", "meaning": "Excuse me, a menu please.", "start": 0.0, "end": 1.99}, {"spk": "her", "ja": "私はコーヒー。", "romaji": "Watashi wa koohii.", "meaning": "I'll have coffee.", "start": 2.32, "end": 3.98}, {"spk": "me", "ja": "じゃあ、僕はカフェラテ。", "romaji": "Jaa, boku wa kaferate.", "meaning": "Then I'll have a café latte.", "start": 4.31, "end": 6.17}, {"spk": "her", "ja": "ケーキも食べる？", "romaji": "Keeki mo taberu?", "meaning": "Want cake too?", "start": 6.59, "end": 8.07}, {"spk": "me", "ja": "うん、食べたい！", "romaji": "Un, tabetai!", "meaning": "Yeah, I want some!", "start": 8.46, "end": 9.8}, {"spk": "me", "ja": "すみません、注文お願いします。", "romaji": "Sumimasen, chuumon onegai shimasu.", "meaning": "Excuse me, we'd like to order.", "start": 10.86, "end": 13.57}, {"spk": "her", "ja": "わくわくする〜！", "romaji": "Wakuwaku suru!", "meaning": "I'm so excited~!", "start": 13.95, "end": 15.44}]}, {"id": "day08", "title": "Day 8 — making plans & time", "audio": "audio/day08.mp3", "lines": [{"spk": "her", "ja": "明日、何時に出る？", "romaji": "Ashita, nanji ni deru?", "meaning": "Tomorrow, what time shall we leave?", "start": 0.0, "end": 1.77}, {"spk": "me", "ja": "十時はどう？", "romaji": "Juuji wa dou?", "meaning": "How about ten?", "start": 2.14, "end": 3.3}, {"spk": "her", "ja": "ちょっと早いかな。", "romaji": "Chotto hayai kana.", "meaning": "A little early, maybe.", "start": 3.91, "end": 5.44}, {"spk": "me", "ja": "じゃあ、十一時に駅で。", "romaji": "Jaa, juuichiji ni eki de.", "meaning": "Then eleven, at the station.", "start": 5.83, "end": 7.75}, {"spk": "her", "ja": "オッケー！遅れないでね。", "romaji": "Okkee! Okurenai de ne.", "meaning": "Okay! Don't be late, alright?", "start": 8.32, "end": 10.45}, {"spk": "me", "ja": "大丈夫、早く行くよ。", "romaji": "Daijoubu, hayaku iku yo.", "meaning": "It's fine, I'll go early.", "start": 10.79, "end": 12.83}, {"spk": "her", "ja": "楽しみ！", "romaji": "Tanoshimi!", "meaning": "Looking forward to it!", "start": 13.38, "end": 14.24}]}, {"id": "day09", "title": "Day 9 — not feeling well & caring", "audio": "audio/day09.mp3", "lines": [{"spk": "me", "ja": "なんか、頭痛い…", "romaji": "Nanka, atama itai…", "meaning": "My head kinda hurts…", "start": 0.0, "end": 3.08}, {"spk": "her", "ja": "えっ、大丈夫？", "romaji": "E', daijoubu?", "meaning": "Huh, are you okay?", "start": 3.83, "end": 5.56}, {"spk": "me", "ja": "うん、ちょっとだけ。", "romaji": "Un, chotto dake.", "meaning": "Yeah, just a little.", "start": 6.24, "end": 7.87}, {"spk": "her", "ja": "薬、飲んだ？", "romaji": "Kusuri, nonda?", "meaning": "Did you take medicine?", "start": 8.79, "end": 10.51}, {"spk": "me", "ja": "まだ。", "romaji": "Mada.", "meaning": "Not yet.", "start": 11.33, "end": 12.2}, {"spk": "her", "ja": "無理しないで。休んで。", "romaji": "Muri shinai de. Yasunde.", "meaning": "Don't push yourself. Get some rest.", "start": 13.0, "end": 15.36}, {"spk": "me", "ja": "ありがとう。そうする。", "romaji": "Arigatou. Sou suru.", "meaning": "Thanks. I'll do that.", "start": 16.28, "end": 17.84}]}, {"id": "day10", "title": "Day 10 — weather small talk", "audio": "audio/day10.mp3", "lines": [{"spk": "her", "ja": "今日、暑いね〜。", "romaji": "Kyou, atsui ne.", "meaning": "It's hot today, huh~.", "start": 0.0, "end": 1.53}, {"spk": "me", "ja": "ほんと。汗かいた。", "romaji": "Honto. Ase kaita.", "meaning": "Really. I've broken a sweat.", "start": 1.78, "end": 3.96}, {"spk": "her", "ja": "アイス食べたい！", "romaji": "Aisu tabetai!", "meaning": "I want ice cream!", "start": 4.33, "end": 5.67}, {"spk": "me", "ja": "いいね、買いに行こう。", "romaji": "Ii ne, kai ni ikou.", "meaning": "Nice, let's go buy some.", "start": 6.15, "end": 7.82}, {"spk": "her", "ja": "あ、でも雲が…", "romaji": "A, demo kumo ga…", "meaning": "Ah, but the clouds…", "start": 8.26, "end": 10.12}, {"spk": "me", "ja": "雨降りそうだね。", "romaji": "Ame furisou da ne.", "meaning": "Looks like it'll rain.", "start": 10.48, "end": 12.0}, {"spk": "her", "ja": "傘、持って行こう。", "romaji": "Kasa, motte ikou.", "meaning": "Let's take an umbrella.", "start": 12.51, "end": 13.92}]}, {"id": "day11", "title": "Day 11 — chores together", "audio": "audio/day11.mp3", "lines": [{"spk": "her", "ja": "ねえ、ちょっと手伝って。", "romaji": "Nee, chotto tetsudatte.", "meaning": "Hey, help me out a sec.", "start": 0.0, "end": 1.85}, {"spk": "me", "ja": "いいよ。何する？", "romaji": "Ii yo. Nani suru?", "meaning": "Sure. What should I do?", "start": 2.18, "end": 3.69}, {"spk": "her", "ja": "ゴミ、出してくれる？", "romaji": "Gomi, dashite kureru?", "meaning": "Could you take out the trash?", "start": 4.04, "end": 5.78}, {"spk": "me", "ja": "了解。洗濯は？", "romaji": "Ryoukai. Sentaku wa?", "meaning": "Got it. What about the laundry?", "start": 6.16, "end": 8.29}, {"spk": "her", "ja": "もうやったよ。", "romaji": "Mou yatta yo.", "meaning": "Already did it.", "start": 8.64, "end": 9.84}, {"spk": "me", "ja": "さすが！助かる。", "romaji": "Sasuga! Tasukaru.", "meaning": "Impressive! That's a big help.", "start": 10.27, "end": 11.94}, {"spk": "her", "ja": "えへへ、ありがとう。", "romaji": "Ehehe, arigatou.", "meaning": "Hehe, thanks.", "start": 12.18, "end": 14.0}]}, {"id": "day12", "title": "Day 12 — looking back on the day", "audio": "audio/day12.mp3", "lines": [{"spk": "her", "ja": "今日、楽しかったね！", "romaji": "Kyou, tanoshikatta ne!", "meaning": "Today was fun, huh!", "start": 0.0, "end": 1.69}, {"spk": "me", "ja": "うん、すごく楽しかった。", "romaji": "Un, sugoku tanoshikatta.", "meaning": "Yeah, it was really fun.", "start": 2.09, "end": 4.4}, {"spk": "her", "ja": "ご飯も美味しかった。", "romaji": "Gohan mo oishikatta.", "meaning": "The food was delicious too.", "start": 5.0, "end": 6.66}, {"spk": "me", "ja": "また行きたいね。", "romaji": "Mata ikitai ne.", "meaning": "I want to go again.", "start": 7.21, "end": 8.42}, {"spk": "her", "ja": "うん、行こう！", "romaji": "Un, ikou!", "meaning": "Yeah, let's go!", "start": 8.96, "end": 10.23}, {"spk": "me", "ja": "今日はありがとう。", "romaji": "Kyou wa arigatou.", "meaning": "Thanks for today.", "start": 10.81, "end": 12.14}, {"spk": "her", "ja": "こちらこそ。", "romaji": "Kochira koso.", "meaning": "Likewise.", "start": 12.81, "end": 13.84}]}]}
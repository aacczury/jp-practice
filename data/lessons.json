{"lessons": [{"id": "day01", "type": "day", "title": "Day 1 — morning together", "audio": "audio/day01.mp3", "lines": [{"spk": "her", "ja": "おはよう。よく寝た？", "romaji": "Ohayou. Yoku neta?", "meaning": "Good morning. Did you sleep well?", "start": 0.0, "end": 1.69}, {"spk": "me", "ja": "おはよう。うん、よく寝たよ。", "romaji": "Ohayou. Un, yoku neta yo.", "meaning": "Morning. Yeah, I slept well.", "start": 2.4, "end": 4.94}, {"spk": "her", "ja": "朝ごはん、できてるよ。", "romaji": "Asagohan, dekiteru yo.", "meaning": "Breakfast's ready.", "start": 5.66, "end": 7.53}, {"spk": "me", "ja": "ありがとう。いただきます。", "romaji": "Arigatou. Itadakimasu.", "meaning": "Thanks. (said before eating — ~\"let's eat / thanks for the food\")", "start": 8.33, "end": 10.33}, {"spk": "me", "ja": "ごちそうさま。美味しかった！", "romaji": "Gochisousama. Oishikatta!", "meaning": "Thanks for the meal (said after eating). It was delicious!", "start": 11.3, "end": 13.44}, {"spk": "her", "ja": "よかった。", "romaji": "Yokatta.", "meaning": "Glad to hear it.", "start": 14.17, "end": 15.04}]}, {"id": "day02", "type": "day", "title": "Day 2 — coming & going at home", "audio": "audio/day02.mp3", "lines": [{"spk": "me", "ja": "行ってきます！", "romaji": "Ittekimasu!", "meaning": "I'm off! (lit. I'll go and come back)", "start": 0.0, "end": 1.02}, {"spk": "her", "ja": "行ってらっしゃい。気をつけてね。", "romaji": "Itterasshai. Ki o tsukete ne.", "meaning": "Take care! Be careful, okay?", "start": 1.27, "end": 3.56}, {"spk": "me", "ja": "ただいま。", "romaji": "Tadaima.", "meaning": "I'm home.", "start": 5.1, "end": 5.92}, {"spk": "her", "ja": "おかえり。お疲れさま。", "romaji": "Okaeri. Otsukaresama.", "meaning": "Welcome back. Nice work.", "start": 6.23, "end": 8.2}, {"spk": "me", "ja": "お腹すいた〜。ご飯ある？", "romaji": "Onaka suita. Gohan aru?", "meaning": "I'm hungry~. Is there food?", "start": 8.53, "end": 12.64}, {"spk": "her", "ja": "うん、できてるよ。", "romaji": "Un, dekiteru yo.", "meaning": "Yeah, it's ready.", "start": 13.03, "end": 14.66}, {"spk": "me", "ja": "おやすみ。また明日。", "romaji": "Oyasumi. Mata ashita.", "meaning": "Good night. See you tomorrow.", "start": 15.1, "end": 17.18}, {"spk": "her", "ja": "おやすみ〜。", "romaji": "Oyasumi.", "meaning": "Night~.", "start": 17.61, "end": 18.8}]}, {"id": "day03", "type": "day", "title": "Day 3 — feelings & reactions at home", "audio": "audio/day03.mp3", "lines": [{"spk": "her", "ja": "おかえり！疲れた？", "romaji": "Okaeri! Tsukareta?", "meaning": "Welcome back! Are you tired?", "start": 0.0, "end": 1.74}, {"spk": "me", "ja": "ただいま。うん、ちょっと疲れた。", "romaji": "Tadaima. Un, chotto tsukareta.", "meaning": "I'm home. Yeah, a bit tired.", "start": 2.25, "end": 5.56}, {"spk": "her", "ja": "大丈夫？", "romaji": "Daijoubu?", "meaning": "Are you okay?", "start": 6.17, "end": 7.24}, {"spk": "me", "ja": "うん、大丈夫。ありがとう。", "romaji": "Un, daijoubu. Arigatou.", "meaning": "Yeah, I'm fine. Thanks.", "start": 7.65, "end": 10.02}, {"spk": "her", "ja": "今日、カレー作ったよ！", "romaji": "Kyou, karee tsukutta yo!", "meaning": "I made curry today!", "start": 10.72, "end": 12.52}, {"spk": "me", "ja": "ほんと？嬉しい！お腹すいた！", "romaji": "Honto? Ureshii! Onaka suita!", "meaning": "Really? I'm so happy! And I'm hungry!", "start": 13.05, "end": 16.76}, {"spk": "her", "ja": "じゃあ、食べよう！", "romaji": "Jaa, tabeyou!", "meaning": "Then let's eat!", "start": 17.48, "end": 18.76}, {"spk": "me", "ja": "美味しい！", "romaji": "Oishii!", "meaning": "It's delicious!", "start": 19.34, "end": 20.45}, {"spk": "her", "ja": "よかった〜！", "romaji": "Yokatta!", "meaning": "I'm glad!", "start": 21.0, "end": 22.16}]}, {"id": "day04", "type": "day", "title": "Day 4 — asking about things at home", "audio": "audio/day04.mp3", "lines": [{"spk": "me", "ja": "ね、リモコン、どこ？", "romaji": "Ne, rimokon, doko?", "meaning": "Hey, where's the remote?", "start": 0.0, "end": 1.71}, {"spk": "her", "ja": "テーブルの上だよ。", "romaji": "Teeburu no ue da yo.", "meaning": "On the table.", "start": 2.1, "end": 3.64}, {"spk": "me", "ja": "ないよ〜。", "romaji": "Nai yo.", "meaning": "It's not here~.", "start": 3.94, "end": 5.06}, {"spk": "her", "ja": "じゃあ、ソファの下は？", "romaji": "Jaa, sofa no shita wa?", "meaning": "Then how about under the sofa?", "start": 5.48, "end": 7.25}, {"spk": "me", "ja": "あった！", "romaji": "Atta!", "meaning": "Found it!", "start": 7.66, "end": 8.44}, {"spk": "her", "ja": "よかった。ね、それ取って。", "romaji": "Yokatta. Ne, sore totte.", "meaning": "Good. Hey, pass me that.", "start": 8.89, "end": 11.83}, {"spk": "me", "ja": "これ？なに、これ？", "romaji": "Kore? Nani, kore?", "meaning": "This? What is it?", "start": 12.29, "end": 14.39}, {"spk": "her", "ja": "プリン！半分食べる？", "romaji": "Purin! Hanbun taberu?", "meaning": "Pudding! Want half?", "start": 14.77, "end": 16.88}, {"spk": "me", "ja": "食べる！ありがとう！", "romaji": "Taberu! Arigatou!", "meaning": "I do! Thanks!", "start": 17.31, "end": 18.96}]}, {"id": "day05", "type": "day", "title": "Day 5 — weekend plans", "audio": "audio/day05.mp3", "lines": [{"spk": "her", "ja": "ねえ、今日何する？", "romaji": "Nee, kyou nani suru?", "meaning": "Hey, what shall we do today?", "start": 0.0, "end": 1.62}, {"spk": "me", "ja": "天気いいし、出かけよう！", "romaji": "Tenki ii shi, dekakeyou!", "meaning": "The weather's nice, so let's go out!", "start": 2.07, "end": 3.97}, {"spk": "her", "ja": "いいね！どこ行く？", "romaji": "Ii ne! Doko iku?", "meaning": "Nice! Where shall we go?", "start": 4.38, "end": 6.2}, {"spk": "me", "ja": "公園は？散歩しよう。", "romaji": "Kouen wa? Sanpo shiyou.", "meaning": "How about the park? Let's take a walk.", "start": 6.64, "end": 8.61}, {"spk": "her", "ja": "いいね。お弁当作ろうか？", "romaji": "Ii ne. Obentou tsukurou ka?", "meaning": "Good. Shall I make a bento?", "start": 9.0, "end": 11.85}, {"spk": "me", "ja": "ほんと？嬉しい！", "romaji": "Honto? Ureshii!", "meaning": "Really? I'm so happy!", "start": 12.25, "end": 13.95}, {"spk": "her", "ja": "じゃあ、準備しよう。", "romaji": "Jaa, junbi shiyou.", "meaning": "Then let's get ready.", "start": 14.45, "end": 15.92}, {"spk": "me", "ja": "うん、行こう！", "romaji": "Un, ikou!", "meaning": "Yeah, let's go!", "start": 16.28, "end": 17.52}]}, {"id": "day06", "type": "day", "title": "Day 6 — shopping together", "audio": "audio/day06.mp3", "lines": [{"spk": "her", "ja": "これ、かわいい！", "romaji": "Kore, kawaii!", "meaning": "This is cute!", "start": 0.0, "end": 1.52}, {"spk": "me", "ja": "ほんとだ。いくら？", "romaji": "Honto da. Ikura?", "meaning": "It really is. How much?", "start": 1.92, "end": 3.48}, {"spk": "her", "ja": "千二百円だって。", "romaji": "Sen nihyaku en datte.", "meaning": "It says 1,200 yen.", "start": 3.83, "end": 5.64}, {"spk": "me", "ja": "ちょっと高いね。", "romaji": "Chotto takai ne.", "meaning": "A bit pricey, huh.", "start": 5.97, "end": 7.39}, {"spk": "her", "ja": "でも、欲しい！", "romaji": "Demo, hoshii!", "meaning": "But I want it!", "start": 7.74, "end": 8.98}, {"spk": "me", "ja": "じゃあ、これにしよう。", "romaji": "Jaa, kore ni shiyou.", "meaning": "Then let's go with this one.", "start": 9.3, "end": 10.79}, {"spk": "her", "ja": "やった！ありがとう！", "romaji": "Yatta! Arigatou!", "meaning": "Yay! Thank you!", "start": 11.19, "end": 12.72}]}, {"id": "day07", "type": "day", "title": "Day 7 — ordering at a café", "audio": "audio/day07.mp3", "lines": [{"spk": "me", "ja": "すみません、メニューください。", "romaji": "Sumimasen, menyuu kudasai.", "meaning": "Excuse me, a menu please.", "start": 0.0, "end": 1.99}, {"spk": "her", "ja": "私はコーヒー。", "romaji": "Watashi wa koohii.", "meaning": "I'll have coffee.", "start": 2.32, "end": 3.98}, {"spk": "me", "ja": "じゃあ、僕はカフェラテ。", "romaji": "Jaa, boku wa kaferate.", "meaning": "Then I'll have a café latte.", "start": 4.31, "end": 6.17}, {"spk": "her", "ja": "ケーキも食べる？", "romaji": "Keeki mo taberu?", "meaning": "Want cake too?", "start": 6.59, "end": 8.07}, {"spk": "me", "ja": "うん、食べたい！", "romaji": "Un, tabetai!", "meaning": "Yeah, I want some!", "start": 8.46, "end": 9.8}, {"spk": "me", "ja": "すみません、注文お願いします。", "romaji": "Sumimasen, chuumon onegai shimasu.", "meaning": "Excuse me, we'd like to order.", "start": 10.86, "end": 13.57}, {"spk": "her", "ja": "わくわくする〜！", "romaji": "Wakuwaku suru!", "meaning": "I'm so excited~!", "start": 13.95, "end": 15.44}]}, {"id": "day08", "type": "day", "title": "Day 8 — making plans & time", "audio": "audio/day08.mp3", "lines": [{"spk": "her", "ja": "明日、何時に出る？", "romaji": "Ashita, nanji ni deru?", "meaning": "Tomorrow, what time shall we leave?", "start": 0.0, "end": 1.77}, {"spk": "me", "ja": "十時はどう？", "romaji": "Juuji wa dou?", "meaning": "How about ten?", "start": 2.14, "end": 3.3}, {"spk": "her", "ja": "ちょっと早いかな。", "romaji": "Chotto hayai kana.", "meaning": "A little early, maybe.", "start": 3.91, "end": 5.44}, {"spk": "me", "ja": "じゃあ、十一時に駅で。", "romaji": "Jaa, juuichiji ni eki de.", "meaning": "Then eleven, at the station.", "start": 5.83, "end": 7.75}, {"spk": "her", "ja": "オッケー！遅れないでね。", "romaji": "Okkee! Okurenai de ne.", "meaning": "Okay! Don't be late, alright?", "start": 8.32, "end": 10.45}, {"spk": "me", "ja": "大丈夫、早く行くよ。", "romaji": "Daijoubu, hayaku iku yo.", "meaning": "It's fine, I'll go early.", "start": 10.79, "end": 12.83}, {"spk": "her", "ja": "楽しみ！", "romaji": "Tanoshimi!", "meaning": "Looking forward to it!", "start": 13.38, "end": 14.24}]}, {"id": "day09", "type": "day", "title": "Day 9 — not feeling well & caring", "audio": "audio/day09.mp3", "lines": [{"spk": "me", "ja": "なんか、頭痛い…", "romaji": "Nanka, atama itai…", "meaning": "My head kinda hurts…", "start": 0.0, "end": 3.08}, {"spk": "her", "ja": "えっ、大丈夫？", "romaji": "E', daijoubu?", "meaning": "Huh, are you okay?", "start": 3.83, "end": 5.56}, {"spk": "me", "ja": "うん、ちょっとだけ。", "romaji": "Un, chotto dake.", "meaning": "Yeah, just a little.", "start": 6.24, "end": 7.87}, {"spk": "her", "ja": "薬、飲んだ？", "romaji": "Kusuri, nonda?", "meaning": "Did you take medicine?", "start": 8.79, "end": 10.51}, {"spk": "me", "ja": "まだ。", "romaji": "Mada.", "meaning": "Not yet.", "start": 11.33, "end": 12.2}, {"spk": "her", "ja": "無理しないで。休んで。", "romaji": "Muri shinai de. Yasunde.", "meaning": "Don't push yourself. Get some rest.", "start": 13.0, "end": 15.36}, {"spk": "me", "ja": "ありがとう。そうする。", "romaji": "Arigatou. Sou suru.", "meaning": "Thanks. I'll do that.", "start": 16.28, "end": 17.84}]}, {"id": "day10", "type": "day", "title": "Day 10 — weather small talk", "audio": "audio/day10.mp3", "lines": [{"spk": "her", "ja": "今日、暑いね〜。", "romaji": "Kyou, atsui ne.", "meaning": "It's hot today, huh~.", "start": 0.0, "end": 1.53}, {"spk": "me", "ja": "ほんと。汗かいた。", "romaji": "Honto. Ase kaita.", "meaning": "Really. I've broken a sweat.", "start": 1.78, "end": 3.96}, {"spk": "her", "ja": "アイス食べたい！", "romaji": "Aisu tabetai!", "meaning": "I want ice cream!", "start": 4.33, "end": 5.67}, {"spk": "me", "ja": "いいね、買いに行こう。", "romaji": "Ii ne, kai ni ikou.", "meaning": "Nice, let's go buy some.", "start": 6.15, "end": 7.82}, {"spk": "her", "ja": "あ、でも雲が…", "romaji": "A, demo kumo ga…", "meaning": "Ah, but the clouds…", "start": 8.26, "end": 10.12}, {"spk": "me", "ja": "雨降りそうだね。", "romaji": "Ame furisou da ne.", "meaning": "Looks like it'll rain.", "start": 10.48, "end": 12.0}, {"spk": "her", "ja": "傘、持って行こう。", "romaji": "Kasa, motte ikou.", "meaning": "Let's take an umbrella.", "start": 12.51, "end": 13.92}]}, {"id": "day11", "type": "day", "title": "Day 11 — chores together", "audio": "audio/day11.mp3", "lines": [{"spk": "her", "ja": "ねえ、ちょっと手伝って。", "romaji": "Nee, chotto tetsudatte.", "meaning": "Hey, help me out a sec.", "start": 0.0, "end": 1.85}, {"spk": "me", "ja": "いいよ。何する？", "romaji": "Ii yo. Nani suru?", "meaning": "Sure. What should I do?", "start": 2.18, "end": 3.69}, {"spk": "her", "ja": "ゴミ、出してくれる？", "romaji": "Gomi, dashite kureru?", "meaning": "Could you take out the trash?", "start": 4.04, "end": 5.78}, {"spk": "me", "ja": "了解。洗濯は？", "romaji": "Ryoukai. Sentaku wa?", "meaning": "Got it. What about the laundry?", "start": 6.16, "end": 8.29}, {"spk": "her", "ja": "もうやったよ。", "romaji": "Mou yatta yo.", "meaning": "Already did it.", "start": 8.64, "end": 9.84}, {"spk": "me", "ja": "さすが！助かる。", "romaji": "Sasuga! Tasukaru.", "meaning": "Impressive! That's a big help.", "start": 10.27, "end": 11.94}, {"spk": "her", "ja": "えへへ、ありがとう。", "romaji": "Ehehe, arigatou.", "meaning": "Hehe, thanks.", "start": 12.18, "end": 14.0}]}, {"id": "day12", "type": "day", "title": "Day 12 — looking back on the day", "audio": "audio/day12.mp3", "lines": [{"spk": "her", "ja": "今日、楽しかったね！", "romaji": "Kyou, tanoshikatta ne!", "meaning": "Today was fun, huh!", "start": 0.0, "end": 1.69}, {"spk": "me", "ja": "うん、すごく楽しかった。", "romaji": "Un, sugoku tanoshikatta.", "meaning": "Yeah, it was really fun.", "start": 2.09, "end": 4.4}, {"spk": "her", "ja": "ご飯も美味しかった。", "romaji": "Gohan mo oishikatta.", "meaning": "The food was delicious too.", "start": 5.0, "end": 6.66}, {"spk": "me", "ja": "また行きたいね。", "romaji": "Mata ikitai ne.", "meaning": "I want to go again.", "start": 7.21, "end": 8.42}, {"spk": "her", "ja": "うん、行こう！", "romaji": "Un, ikou!", "meaning": "Yeah, let's go!", "start": 8.96, "end": 10.23}, {"spk": "me", "ja": "今日はありがとう。", "romaji": "Kyou wa arigatou.", "meaning": "Thanks for today.", "start": 10.81, "end": 12.14}, {"spk": "her", "ja": "こちらこそ。", "romaji": "Kochira koso.", "meaning": "Likewise.", "start": 12.81, "end": 13.84}]}, {"id": "day13", "type": "day", "title": "Day 13 — phone & staying in touch", "audio": "audio/day13.mp3", "lines": [{"spk": "me", "ja": "もしもし、今どこ？", "romaji": "Moshimoshi, ima doko?", "meaning": "Hello? Where are you now?", "start": 0.0, "end": 1.61}, {"spk": "her", "ja": "もうすぐ着くよ！", "romaji": "Mou sugu tsuku yo!", "meaning": "I'm almost there!", "start": 1.88, "end": 3.3}, {"spk": "me", "ja": "わかった、待ってるね。", "romaji": "Wakatta, matteru ne.", "meaning": "Got it — I'll wait.", "start": 3.66, "end": 5.24}, {"spk": "her", "ja": "ごめん、五分くらい遅れる。", "romaji": "Gomen, gofun kurai okureru.", "meaning": "Sorry, I'll be about five minutes late.", "start": 5.84, "end": 8.12}, {"spk": "me", "ja": "大丈夫、急がないで。", "romaji": "Daijoubu, isoganaide.", "meaning": "It's fine, don't rush.", "start": 8.48, "end": 10.08}, {"spk": "her", "ja": "ありがとう、すぐ行くね！", "romaji": "Arigatou, sugu iku ne!", "meaning": "Thanks, I'll be right there!", "start": 10.59, "end": 12.48}]}, {"id": "day14", "type": "day", "title": "Day 14 — at the convenience store", "audio": "audio/day14.mp3", "lines": [{"spk": "me", "ja": "すみません、これください。", "romaji": "Sumimasen, kore kudasai.", "meaning": "Excuse me, this one please.", "start": 0.0, "end": 1.91}, {"spk": "her", "ja": "袋はいりますか？", "romaji": "Fukuro wa irimasu ka?", "meaning": "Do you need a bag?", "start": 2.28, "end": 3.94}, {"spk": "me", "ja": "いえ、大丈夫です。", "romaji": "Ie, daijoubu desu.", "meaning": "No, I'm okay.", "start": 4.38, "end": 5.89}, {"spk": "her", "ja": "温めますか？", "romaji": "Atatamemasu ka?", "meaning": "Shall I heat it up?", "start": 6.55, "end": 7.98}, {"spk": "me", "ja": "はい、お願いします。", "romaji": "Hai, onegai shimasu.", "meaning": "Yes, please.", "start": 8.45, "end": 10.13}, {"spk": "her", "ja": "ありがとうございます。", "romaji": "Arigatou gozaimasu.", "meaning": "Thank you very much.", "start": 10.63, "end": 12.24}]}, {"id": "day15", "type": "day", "title": "Day 15 — asking directions", "audio": "audio/day15.mp3", "lines": [{"spk": "me", "ja": "すみません、駅はどこですか？", "romaji": "Sumimasen, eki wa doko desu ka?", "meaning": "Excuse me, where is the station?", "start": 0.0, "end": 2.3}, {"spk": "her", "ja": "まっすぐ行って、右です。", "romaji": "Massugu itte, migi desu.", "meaning": "Go straight, then it's on the right.", "start": 2.71, "end": 4.83}, {"spk": "me", "ja": "歩いてどれくらい？", "romaji": "Aruite dorekurai?", "meaning": "How long on foot?", "start": 5.45, "end": 6.95}, {"spk": "her", "ja": "五分くらいかな。", "romaji": "Gofun kurai kana.", "meaning": "About five minutes, I'd say.", "start": 7.34, "end": 8.92}, {"spk": "me", "ja": "ありがとうございます！", "romaji": "Arigatou gozaimasu!", "meaning": "Thank you so much!", "start": 9.42, "end": 10.8}, {"spk": "her", "ja": "気をつけてね。", "romaji": "Ki o tsukete ne.", "meaning": "Take care.", "start": 11.24, "end": 12.32}]}, {"id": "day16", "type": "day", "title": "Day 16 — catching the train", "audio": "audio/day16.mp3", "lines": [{"spk": "me", "ja": "次の電車、何時？", "romaji": "Tsugi no densha, nanji?", "meaning": "What time is the next train?", "start": 0.0, "end": 1.68}, {"spk": "her", "ja": "十時十五分だよ。", "romaji": "Juuji juugofun da yo.", "meaning": "It's 10:15.", "start": 2.11, "end": 3.9}, {"spk": "me", "ja": "何番線？", "romaji": "Nanbansen?", "meaning": "Which platform?", "start": 4.25, "end": 5.27}, {"spk": "her", "ja": "三番線。急ごう！", "romaji": "Sanbansen. Isogou!", "meaning": "Platform 3. Let's hurry!", "start": 5.54, "end": 7.66}, {"spk": "me", "ja": "間に合うかな。", "romaji": "Maniau kana.", "meaning": "I wonder if we'll make it.", "start": 8.12, "end": 9.5}, {"spk": "her", "ja": "走れば大丈夫！", "romaji": "Hashireba daijoubu!", "meaning": "If we run, we'll be fine!", "start": 9.92, "end": 11.44}]}, {"id": "day17", "type": "day", "title": "Day 17 — at a restaurant", "audio": "audio/day17.mp3", "lines": [{"spk": "me", "ja": "予約してないけど、大丈夫ですか？", "romaji": "Yoyaku shitenai kedo, daijoubu desu ka?", "meaning": "We don't have a reservation — is that okay?", "start": 0.0, "end": 2.39}, {"spk": "her", "ja": "はい、こちらへどうぞ。", "romaji": "Hai, kochira e douzo.", "meaning": "Yes, right this way.", "start": 2.79, "end": 4.66}, {"spk": "me", "ja": "おすすめは何ですか？", "romaji": "Osusume wa nan desu ka?", "meaning": "What do you recommend?", "start": 5.19, "end": 6.82}, {"spk": "her", "ja": "今日は魚が新鮮ですよ。", "romaji": "Kyou wa sakana ga shinsen desu yo.", "meaning": "The fish is fresh today.", "start": 7.31, "end": 9.86}, {"spk": "me", "ja": "じゃあ、それにします。", "romaji": "Jaa, sore ni shimasu.", "meaning": "Then I'll have that.", "start": 10.38, "end": 11.93}, {"spk": "her", "ja": "かしこまりました。", "romaji": "Kashikomarimashita.", "meaning": "Certainly.", "start": 12.29, "end": 13.6}]}, {"id": "day18", "type": "day", "title": "Day 18 — making a plan / inviting", "audio": "audio/day18.mp3", "lines": [{"spk": "her", "ja": "今度、映画行かない？", "romaji": "Kondo, eiga ikanai?", "meaning": "Want to go see a movie sometime?", "start": 0.0, "end": 1.67}, {"spk": "me", "ja": "いいね！いつ空いてる？", "romaji": "Ii ne! Itsu aiteru?", "meaning": "Nice! When are you free?", "start": 2.12, "end": 4.06}, {"spk": "her", "ja": "土曜日はどう？", "romaji": "Doyoubi wa dou?", "meaning": "How about Saturday?", "start": 4.45, "end": 5.81}, {"spk": "me", "ja": "土曜日いいよ。楽しみ！", "romaji": "Doyoubi ii yo. Tanoshimi!", "meaning": "Saturday works. Looking forward to it!", "start": 6.26, "end": 8.08}, {"spk": "her", "ja": "何見たい？", "romaji": "Nani mitai?", "meaning": "What do you want to watch?", "start": 8.53, "end": 9.71}, {"spk": "me", "ja": "なんでもいいよ、君が選んで。", "romaji": "Nandemo ii yo, kimi ga erande.", "meaning": "Anything's fine — you pick.", "start": 10.18, "end": 12.48}]}, {"id": "day19", "type": "day", "title": "Day 19 — compliments", "audio": "audio/day19.mp3", "lines": [{"spk": "me", "ja": "その服、似合ってるね。", "romaji": "Sono fuku, niatteru ne.", "meaning": "That outfit suits you.", "start": 0.0, "end": 1.93}, {"spk": "her", "ja": "ほんと？ありがとう！", "romaji": "Honto? Arigatou!", "meaning": "Really? Thanks!", "start": 2.27, "end": 4.05}, {"spk": "me", "ja": "うん、すごくかわいい。", "romaji": "Un, sugoku kawaii.", "meaning": "Yeah, really cute.", "start": 4.45, "end": 6.44}, {"spk": "her", "ja": "君も今日かっこいいよ。", "romaji": "Kimi mo kyou kakkoii yo.", "meaning": "You look cool today too.", "start": 6.91, "end": 9.0}, {"spk": "me", "ja": "えへへ、照れるなあ。", "romaji": "Ehehe, tereru naa.", "meaning": "Hehe, you're making me blush.", "start": 9.53, "end": 11.73}, {"spk": "her", "ja": "ふふ、行こっか。", "romaji": "Fufu, ikokka.", "meaning": "Hehe, shall we go?", "start": 12.16, "end": 13.92}]}, {"id": "day20", "type": "day", "title": "Day 20 — saying sorry & making up", "audio": "audio/day20.mp3", "lines": [{"spk": "me", "ja": "さっきはごめんね。", "romaji": "Sakki wa gomen ne.", "meaning": "Sorry about earlier.", "start": 0.0, "end": 1.38}, {"spk": "her", "ja": "ううん、大丈夫だよ。", "romaji": "Uun, daijoubu da yo.", "meaning": "No, it's okay.", "start": 1.95, "end": 4.34}, {"spk": "me", "ja": "ちょっと言い過ぎた。", "romaji": "Chotto iisugita.", "meaning": "I said a bit too much.", "start": 4.85, "end": 6.23}, {"spk": "her", "ja": "気にしないで。", "romaji": "Ki ni shinaide.", "meaning": "Don't worry about it.", "start": 6.89, "end": 8.18}, {"spk": "me", "ja": "ありがとう。次から気をつける。", "romaji": "Arigatou. Tsugi kara ki o tsukeru.", "meaning": "Thanks. I'll be careful from now on.", "start": 8.99, "end": 11.56}, {"spk": "her", "ja": "うん、仲直り！", "romaji": "Un, nakanaori!", "meaning": "Yeah — let's make up!", "start": 12.18, "end": 14.24}]}, {"id": "day21", "type": "day", "title": "Day 21 — dreams & promises", "audio": "audio/day21.mp3", "lines": [{"spk": "her", "ja": "いつか海外、行きたいね。", "romaji": "Itsuka kaigai, ikitai ne.", "meaning": "I want to go abroad someday.", "start": 0.0, "end": 2.2}, {"spk": "me", "ja": "いいね、どこ行きたい？", "romaji": "Ii ne, doko ikitai?", "meaning": "Nice — where do you want to go?", "start": 2.74, "end": 4.7}, {"spk": "her", "ja": "うーん、日本かな。", "romaji": "Uun, Nihon kana.", "meaning": "Hmm, Japan, I think.", "start": 5.26, "end": 7.43}, {"spk": "me", "ja": "じゃあ、一緒に行こう。", "romaji": "Jaa, issho ni ikou.", "meaning": "Then let's go together.", "start": 8.0, "end": 9.36}, {"spk": "her", "ja": "約束だよ？", "romaji": "Yakusoku da yo?", "meaning": "It's a promise, okay?", "start": 10.0, "end": 11.32}, {"spk": "me", "ja": "うん、約束。", "romaji": "Un, yakusoku.", "meaning": "Yeah, a promise.", "start": 12.64, "end": 13.36}]}, {"id": "day22", "type": "day", "title": "Day 22 — the seasons", "audio": "audio/day22.mp3", "lines": [{"spk": "her", "ja": "最近、寒くなってきたね。", "romaji": "Saikin, samuku natte kita ne.", "meaning": "It's been getting colder lately.", "start": 0.0, "end": 2.04}, {"spk": "me", "ja": "ほんと、もう冬だね。", "romaji": "Honto, mou fuyu da ne.", "meaning": "Really, it's winter already.", "start": 2.39, "end": 4.5}, {"spk": "her", "ja": "今度、紅葉見に行こう。", "romaji": "Kondo, kouyou mi ni ikou.", "meaning": "Let's go see the autumn leaves sometime.", "start": 4.87, "end": 6.96}, {"spk": "me", "ja": "いいね！あったかくして行こう。", "romaji": "Ii ne! Attakaku shite ikou.", "meaning": "Nice! Let's bundle up and go.", "start": 7.41, "end": 9.86}, {"spk": "her", "ja": "マフラー持ってくね。", "romaji": "Mafuraa motteku ne.", "meaning": "I'll bring a scarf.", "start": 10.22, "end": 11.78}, {"spk": "me", "ja": "うん、楽しみ！", "romaji": "Un, tanoshimi!", "meaning": "Yeah, looking forward to it!", "start": 12.14, "end": 13.44}]}, {"id": "day23", "type": "day", "title": "Day 23 — offering to help", "audio": "audio/day23.mp3", "lines": [{"spk": "her", "ja": "荷物、重そう。持とうか？", "romaji": "Nimotsu, omosou. Motou ka?", "meaning": "Your bag looks heavy. Shall I carry it?", "start": 0.0, "end": 2.77}, {"spk": "me", "ja": "ありがとう、でも大丈夫。", "romaji": "Arigatou, demo daijoubu.", "meaning": "Thanks, but I'm okay.", "start": 3.39, "end": 5.56}, {"spk": "her", "ja": "無理しないで。", "romaji": "Muri shinaide.", "meaning": "Don't push yourself.", "start": 6.09, "end": 7.42}, {"spk": "me", "ja": "じゃあ、半分お願い。", "romaji": "Jaa, hanbun onegai.", "meaning": "Then, take half, please.", "start": 7.94, "end": 9.59}, {"spk": "her", "ja": "まかせて！", "romaji": "Makasete!", "meaning": "Leave it to me!", "start": 10.2, "end": 11.21}, {"spk": "me", "ja": "助かるよ、ありがとう。", "romaji": "Tasukaru yo, arigatou.", "meaning": "That helps — thanks.", "start": 11.81, "end": 13.44}]}, {"id": "day24", "type": "day", "title": "Day 24 — looking back, two weeks in", "audio": "audio/day24.mp3", "lines": [{"spk": "her", "ja": "最近、日本語うまくなったね。", "romaji": "Saikin, nihongo umaku natta ne.", "meaning": "Your Japanese has gotten good lately.", "start": 0.0, "end": 2.46}, {"spk": "me", "ja": "ほんと？嬉しい！", "romaji": "Honto? Ureshii!", "meaning": "Really? I'm happy!", "start": 3.08, "end": 4.86}, {"spk": "her", "ja": "毎日がんばってるもんね。", "romaji": "Mainichi ganbatteru mon ne.", "meaning": "You work hard every day, after all.", "start": 5.52, "end": 7.61}, {"spk": "me", "ja": "君のおかげだよ。", "romaji": "Kimi no okage da yo.", "meaning": "It's thanks to you.", "start": 8.33, "end": 9.62}, {"spk": "her", "ja": "これからも一緒にがんばろう。", "romaji": "Korekara mo issho ni ganbarou.", "meaning": "Let's keep at it together from here on.", "start": 10.25, "end": 12.67}, {"spk": "me", "ja": "うん、これからもよろしく。", "romaji": "Un, korekara mo yoroshiku.", "meaning": "Yeah — let's keep going together.", "start": 14.2, "end": 15.36}]}, {"id": "song-marigold", "type": "song", "title": "あいみょん — マリーゴールド (Marigold)", "youtube": {"id": "0xSiBpUdW4E", "offset": 0.0}, "lines": [{"ja": "風の強さがちょっと　心を揺さぶりすぎて", "romaji": "Kaze no tsuyosa ga chotto, kokoro o yusaburi sugite", "meaning": "The wind's strength shakes my heart a little too much", "clip": "audio/song-marigold-0.mp3", "yt": 20.9, "ytEnd": 29.6}, {"ja": "真面目に見つめた　君が恋しい", "romaji": "Majime ni mitsumeta, kimi ga koishii", "meaning": "I miss you — the one I gazed at so earnestly", "clip": "audio/song-marigold-1.mp3", "yt": 29.6, "ytEnd": 39.1}, {"ja": "麦わらの帽子の君が　揺れたマリーゴールドに似てる", "romaji": "Mugiwara no boushi no kimi ga, yureta marīgōrudo ni niteru", "meaning": "You in your straw hat are like a swaying marigold", "clip": "audio/song-marigold-2.mp3", "yt": 64.9, "ytEnd": 74.9}, {"ja": "あれは空がまだ青い夏のこと", "romaji": "Are wa sora ga mada aoi natsu no koto", "meaning": "That was a summer when the sky was still blue", "clip": "audio/song-marigold-3.mp3", "yt": 74.9, "ytEnd": 79.2}, {"ja": "懐かしいと笑えたあの日の恋", "romaji": "Natsukashii to waraeta ano hi no koi", "meaning": "The love of those days we could smile back on", "clip": "audio/song-marigold-4.mp3", "yt": 79.2, "ytEnd": 84.1}, {"ja": "「もう離れないで」と　泣きそうな目で見つめる君を", "romaji": "\"Mou hanarenai de\" to, nakisou na me de mitsumeru kimi o", "meaning": "You, gazing with near-tearful eyes — \"don't leave me anymore\"", "clip": "audio/song-marigold-5.mp3", "yt": 84.1, "ytEnd": 92.8}, {"ja": "雲のような優しさでそっとぎゅっと", "romaji": "Kumo no you na yasashisa de sotto gyutto", "meaning": "With a cloud-like gentleness, softly, tightly", "clip": "audio/song-marigold-6.mp3", "yt": 92.8, "ytEnd": 97.4}, {"ja": "抱きしめて　抱きしめて　離さない", "romaji": "Dakishimete, dakishimete, hanasanai", "meaning": "I hold you, hold you, and won't let go", "clip": "audio/song-marigold-7.mp3", "yt": 97.4, "ytEnd": 104.1}]}, {"id": "song-shinunoga-e-wa", "type": "song", "title": "Fujii Kaze — 死ぬのがいいわ (Shinunoga E-Wa)", "youtube": {"id": "dawrQnvwMTY", "offset": 0.0}, "lines": [{"ja": "指切りげんまん ホラでも吹いたら", "romaji": "Yubikiri genman, hora demo fuitara", "meaning": "Pinky promise — if I ever tell a lie…", "clip": "audio/song-shinunoga-e-wa-0.mp3", "yt": 24.9, "ytEnd": 29.1}, {"ja": "針でもなんでも 飲ませていただき Monday", "romaji": "Hari demo nan demo nomasete itadaki Monday", "meaning": "…I'll swallow a thousand needles, whatever — wordplay: いただきます → \"itadaki-Monday\"", "clip": "audio/song-shinunoga-e-wa-1.mp3", "yt": 29.1, "ytEnd": 32.8}, {"ja": "It doesn't matter if it's Sunday", "romaji": "(English line)", "meaning": "Sung as-is.", "clip": "audio/song-shinunoga-e-wa-2.mp3", "yt": 32.8, "ytEnd": 37.1}, {"ja": "鏡よ鏡よ この世で1番", "romaji": "Kagami yo kagami yo, kono yo de ichiban", "meaning": "Mirror, mirror — who in this world…", "clip": "audio/song-shinunoga-e-wa-3.mp3", "yt": 37.1, "ytEnd": 40.5}, {"ja": "変わることのない 愛をくれるのはだれ", "romaji": "Kawaru koto no nai ai o kureru no wa dare", "meaning": "…gives me a love that never changes?", "clip": "audio/song-shinunoga-e-wa-4.mp3", "yt": 40.5, "ytEnd": 45.0}, {"ja": "No need to ask 'cause it's my darling", "romaji": "(English line)", "meaning": "Sung as-is.", "clip": "audio/song-shinunoga-e-wa-5.mp3", "yt": 45.0, "ytEnd": 49.2}, {"ja": "わたしの最後はあなたがいい", "romaji": "Watashi no saigo wa anata ga ii", "meaning": "I want my last moment to be with you", "clip": "audio/song-shinunoga-e-wa-6.mp3", "yt": 49.2, "ytEnd": 52.5}, {"ja": "あなたとこのままおサラバするより", "romaji": "Anata to kono mama o-saraba suru yori", "meaning": "Rather than saying goodbye to you like this…", "clip": "audio/song-shinunoga-e-wa-7.mp3", "yt": 52.5, "ytEnd": 55.5}, {"ja": "死ぬのがいいわ", "romaji": "Shinu no ga ii wa", "meaning": "…I'd rather die", "clip": "audio/song-shinunoga-e-wa-8.mp3", "yt": 55.5, "ytEnd": 61.5}, {"ja": "死ぬのがいいわ", "romaji": "Shinu no ga ii wa", "meaning": "(repeat — the hook)", "clip": "audio/song-shinunoga-e-wa-9.mp3", "yt": 55.5, "ytEnd": 61.5}, {"ja": "三度の飯よりあんたがいいのよ", "romaji": "Sando no meshi yori anta ga ii no yo", "meaning": "I love you more than my three meals a day", "clip": "audio/song-shinunoga-e-wa-10.mp3", "yt": 61.5, "ytEnd": 65.0}, {"ja": "あんたとこのままおサラバするよか", "romaji": "Anta to kono mama o-saraba suru yoka", "meaning": "Rather than parting with you like this… (よか = casual より)", "clip": "audio/song-shinunoga-e-wa-11.mp3", "yt": 65.0, "ytEnd": 73.3}, {"ja": "死ぬのがいいわ", "romaji": "Shinu no ga ii wa", "meaning": "…I'd rather die", "clip": "audio/song-shinunoga-e-wa-12.mp3", "yt": 55.5, "ytEnd": 61.5}, {"ja": "死ぬのがいいわ", "romaji": "Shinu no ga ii wa", "meaning": "(repeat)", "clip": "audio/song-shinunoga-e-wa-13.mp3", "yt": 55.5, "ytEnd": 61.5}]}, {"id": "song-tabiji", "type": "song", "title": "藤井風 — 旅路 (Tabiji)", "youtube": {"id": "29p8FvT_puU", "offset": 3.2}, "lines": [{"ja": "あの日のことは　忘れてね", "romaji": "Ano hi no koto wa wasurete ne", "meaning": "Forget about that day, okay?", "clip": "audio/song-tabiji-0.mp3", "yt": 22.8, "ytEnd": 29.2}, {"ja": "幼すぎて　知らなかった", "romaji": "Osanasugite shiranakatta", "meaning": "I was too young — I didn't know", "clip": "audio/song-tabiji-1.mp3", "yt": 29.2, "ytEnd": 34.1}, {"ja": "恥ずかしくて　消えたいけど", "romaji": "Hazukashikute kietai kedo", "meaning": "So embarrassed I want to vanish, but…", "clip": "audio/song-tabiji-2.mp3", "yt": 34.1, "ytEnd": 40.0}, {"ja": "もう大丈夫　旅路は続く", "romaji": "Mou daijoubu, tabiji wa tsuzuku", "meaning": "It's okay now — the journey goes on", "clip": "audio/song-tabiji-3.mp3", "yt": 40.0, "ytEnd": 45.6}, {"ja": "お元気ですか", "romaji": "O-genki desu ka", "meaning": "How are you doing?", "clip": "audio/song-tabiji-4.mp3", "yt": 143.0, "ytEnd": 145.8}, {"ja": "この町は相変わらず青春です", "romaji": "Kono machi wa aikawarazu seishun desu", "meaning": "This town is, as ever, full of youth", "clip": "audio/song-tabiji-5.mp3", "yt": 145.8, "ytEnd": 154.1}, {"ja": "誰もがみな走ってます", "romaji": "Daremo ga mina hashittemasu", "meaning": "Everyone's running", "clip": "audio/song-tabiji-6.mp3", "yt": 154.1, "ytEnd": 159.9}, {"ja": "まだ見えない旅路の先へ", "romaji": "Mada mienai tabiji no saki e", "meaning": "Toward the still-unseen end of the journey", "clip": "audio/song-tabiji-7.mp3", "yt": 159.9, "ytEnd": 167.9}]}]}